{
  "manifest_version": 3,
  "name": "YTMusic Floating Widget",
  "version": "1.1.0",
  "description": "Widget flotante nativo con controles de YouTube Music.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "http://localhost:23567/*"
  ],
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTMusic Widget",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}

